# Supabase - Dapatkan dari: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini AI - Dapatkan dari: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Apps Script (GAS) - Upload file ke Google Drive
# Deploy GAS sebagai Web App, paste URL-nya di sini
NEXT_PUBLIC_GAS_WEB_APP_URL=your_gas_web_app_url_here

